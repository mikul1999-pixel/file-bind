{
  "name": "file-bind",
  "displayName": "File Bind",
  "description": "Bind files to keyboard shortcuts for quick navigation",
  "version": "0.1.2",
  "icon": "media/icon.png",
  "publisher": "mikul",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikul1999-pixel/file-bind.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "file-bind.configureKeybindings",
        "title": "File Bind: Configure Keybindings"
      },
      {
        "command": "file-bind.openConfig",
        "title": "File Bind: Configure Slots"
      },
      {
        "command": "file-bind.pinToSlot",
        "title": "File Bind: Pin Current File to Slot"
      },
      {
        "command": "file-bind.jumpToSlot",
        "title": "File Bind: Jump to Slot"
      },
      {
        "command": "file-bind.clearSlot",
        "title": "File Bind: Clear Slot"
      },
      {
        "command": "file-bind.showStatus",
        "title": "File Bind: Show Bound Files"
      },
      {
        "command": "file-bind.jumpPrevious",
        "title": "File Bind: Jump to Previous File"
      },
      {
        "command": "file-bind.cycleSlotsForward",
        "title": "File Bind: Cycle Slots Forward"
      },
      {
        "command": "file-bind.cycleSlotsBackward",
        "title": "File Bind: Cycle Slots Backward"
      }
    ],
    "keybindings": [
      {
        "command": "file-bind.jumpPrevious",
        "key": "alt+q",
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.cycleSlotsForward",
        "key": "alt+]",
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.cycleSlotsBackward",
        "key": "alt+[",
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.jumpToSlot",
        "key": "alt+1",
        "args": 1,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.jumpToSlot",
        "key": "alt+2",
        "args": 2,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.jumpToSlot",
        "key": "alt+3",
        "args": 3,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.jumpToSlot",
        "key": "alt+4",
        "args": 4,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.jumpToSlot",
        "key": "alt+5",
        "args": 5,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.jumpToSlot",
        "key": "alt+6",
        "args": 6,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.jumpToSlot",
        "key": "alt+7",
        "args": 7,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.jumpToSlot",
        "key": "alt+8",
        "args": 8,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.jumpToSlot",
        "key": "alt+9",
        "args": 9,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.pinToSlot",
        "key": "alt+shift+1",
        "args": 1,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.pinToSlot",
        "key": "alt+shift+2",
        "args": 2,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.pinToSlot",
        "key": "alt+shift+3",
        "args": 3,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.pinToSlot",
        "key": "alt+shift+4",
        "args": 4,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.pinToSlot",
        "key": "alt+shift+5",
        "args": 5,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.pinToSlot",
        "key": "alt+shift+6",
        "args": 6,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.pinToSlot",
        "key": "alt+shift+7",
        "args": 7,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.pinToSlot",
        "key": "alt+shift+8",
        "args": 8,
        "when": "editorTextFocus"
      },
      {
        "command": "file-bind.pinToSlot",
        "key": "alt+shift+9",
        "args": 9,
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "File Bind",
      "properties": {
        "file-bind.slotCount": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 9,
          "description": "Number of available slots (1-9)"
        },
        "file-bind.statusPreviewLimit": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 9,
          "description": "Number of slots shown in status bar (1-9)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  }
}
